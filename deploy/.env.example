# Vorlage für Secrets des Exponat-Servers (embedded Relay, deploy/docker-compose.yml).
# Kopieren nach deploy/.env (oder Repo-Root .env, siehe unten) und ausfüllen -
# NIE committen (siehe .gitignore: .env / deploy/.env).
#
# Nutzung:
#   cp deploy/.env.example deploy/.env
#   # deploy/.env ausfuellen
#   docker compose -f deploy/docker-compose.yml --env-file deploy/.env up
#
# (docker-compose.yml wird per `-f deploy/docker-compose.yml` referenziert,
# das Standard-Projektverzeichnis fuer die automatische .env-Erkennung ist
# dabei die aktuelle Arbeitsverzeichnis (Repo-Root) - deshalb explizit
# `--env-file deploy/.env` angeben statt auf Auto-Discovery zu vertrauen.)

# Komma-getrennte Exponat-API-Keys (Token-Minting, Bearer-Auth der
# Exponat-Endpunkte, siehe docs/CONNECTION_SERVICE_SPEC.md §3/§5).
# Ohne gesetzten Wert generiert der Server einen TEMPORAEREN Key pro Start
# (nur fuer schnelles Testen - fuer echten Betrieb IMMER selbst setzen).
API_KEYS=

# Admin-Key fuer /admin (Token-Uebersicht, Revoke). Ohne gesetzten Wert wird
# beim ersten Start einer generiert und auf die Console gedruckt + persistent
# in DATA_DIR/admin_key gespeichert (siehe docker-compose.yml `exponat-data`).
ADMIN_KEY=

# Traefik/Let's-Encrypt (nur bei `--profile edge`, eigene Domain statt
# Tailscale-Testing, siehe docs/DEPLOYMENT.md §5 fuer den Tailscale-Pfad).
ACME_EMAIL=admin@example.com
# BasicAuth fuer /admin hinter Traefik: "htpasswd -nB admin" ausfuehren,
# '$' in der Ausgabe zu '$$' verdoppeln (Compose-Escaping).
ADMIN_BASIC_AUTH=admin:$$apr1$$placeholder
