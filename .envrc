# Auto-activate mise (pinnt node + pnpm fuer dieses Repo).
# Nach dem Anlegen einmal `direnv allow` ausfuehren.
# `mise hook-env` statt `mise activate`: direnv wertet .envrc unter
# zsh `emulate sh` aus, wo `mise activate` (zsh/bash-Hooks) mit
# "autoload: command not found" / "arithmetic syntax error" abbrechen
# wuerde. hook-env liefert nur `export`-Zeilen (shell-agnostisch).
eval "$(mise hook-env)"

# npm im Projekt deaktivieren – nur pnpm verwenden.
PATH_add scripts/bin
