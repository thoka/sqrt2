    "globals": "^15.15.0",
    "jsdom": "^29.1.1",
    "knip": "^5.88.1",
    "prettier": "^3.9.5",
    "prettier-plugin-svelte": "^3.5.2",
    "svelte": "^5.56.5",
    "svelte-check": "^4.7.2",
