{
	"name": "sqrt2-flaechenmodell",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "vite build",
		"preview": "vite preview",
		"test": "node --test tests/unit/*.test.js && vitest run",
		"e2e:install": "playwright install chromium",
		"test:e2e": "playwright test",
		"test:relay": "node tests/relay/test-api.mjs && node tests/relay/test-connection.mjs",
		"test:wssync": "node tests/relay/test-sqrt2-sync.mjs",
		"serve": "node server/index.js",
		"test:env": "node --test scripts/check-env.mjs",
		"check": "svelte-check --tsconfig jsconfig.json && eslint . && knip --dependencies && prettier --check .",
		"prepare": "git config core.hooksPath scripts/git-hooks",
		"lint": "eslint .",
		"knip": "knip --dependencies",
		"format": "prettier --write .",
		"format:check": "prettier --check ."
	},
	"lint-staged": {
		"*.{js,svelte}": "eslint",
		"*.{js,svelte,json,css,html}": "prettier --check"
	},
	"dependencies": {
		"qrcode": "^1.5.4",
		"ws": "^8.18.0"
	},
	"packageManager": "pnpm@11.13.0",
	"devDependencies": {
		"@eslint/js": "^9.39.5",
		"@playwright/test": "^1.61.1",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@types/node": "^26.1.1",
		"eslint": "^9.39.5",
		"eslint-plugin-svelte": "^2.46.1",
		"globals": "^15.15.0",
		"jsdom": "^29.1.1",
		"knip": "^5.88.1",
		"lint-staged": "^17.0.8",
		"prettier": "^3.9.5",
		"prettier-plugin-svelte": "^3.5.2",
		"svelte": "^5.56.5",
		"svelte-check": "^4.7.2",
		"vite": "^7.3.6",
		"vitest": "^4.1.10"
	}
}
